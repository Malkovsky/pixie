{
    "version": 4,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 18,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "DISABLE_AVX512": "OFF",
                "ENABLE_ADDRESS_SANITIZER": "OFF",
                "PIXIE_BENCHMARKS": "OFF",
                "PIXIE_COVERAGE": "OFF",
                "PIXIE_DIAGNOSTICS": "OFF",
                "PIXIE_DOCS": "OFF",
                "PIXIE_TESTS": "OFF",
                "PIXIE_THIRD_PARTY_BACKENDS": "OFF"
            }
        },
        {
            "name": "test-base",
            "hidden": true,
            "inherits": "base",
            "cacheVariables": {
                "PIXIE_TESTS": "ON"
            }
        },
        {
            "name": "benchmark-base",
            "hidden": true,
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "PIXIE_BENCHMARKS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": "test-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "inherits": "test-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "asan",
            "displayName": "AddressSanitizer",
            "inherits": "test-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "DISABLE_AVX512": "ON",
                "ENABLE_ADDRESS_SANITIZER": "ON"
            }
        },
        {
            "name": "coverage",
            "displayName": "Coverage",
            "inherits": "test-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "PIXIE_COVERAGE": "ON"
            }
        },
        {
            "name": "benchmarks",
            "displayName": "Benchmarks",
            "inherits": "benchmark-base"
        },
        {
            "name": "benchmark-all-backends",
            "displayName": "Benchmarks with all backends",
            "inherits": "benchmark-base",
            "cacheVariables": {
                "PIXIE_THIRD_PARTY_BACKENDS": "ON"
            }
        },
        {
            "name": "benchmarks-profile",
            "displayName": "Profile benchmarks",
            "inherits": "benchmark-base",
            "cacheVariables": {
                "BENCHMARK_ENABLE_LIBPFM": "ON",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "PIXIE_DIAGNOSTICS": "ON"
            }
        },
        {
            "name": "docs",
            "displayName": "Documentation",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "PIXIE_DOCS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Build Release",
            "configurePreset": "release"
        },
        {
            "name": "asan",
            "displayName": "Build AddressSanitizer",
            "configurePreset": "asan"
        },
        {
            "name": "coverage",
            "displayName": "Build Coverage",
            "configurePreset": "coverage"
        },
        {
            "name": "benchmarks",
            "displayName": "Build Benchmarks",
            "configurePreset": "benchmarks"
        },
        {
            "name": "benchmark-all-backends",
            "displayName": "Build Benchmarks with all backends",
            "configurePreset": "benchmark-all-backends"
        },
        {
            "name": "benchmarks-profile",
            "displayName": "Build Profile Benchmarks",
            "configurePreset": "benchmarks-profile"
        },
        {
            "name": "docs",
            "displayName": "Build Documentation",
            "configurePreset": "docs",
            "targets": [
                "docs"
            ]
        }
    ],
    "testPresets": [
        {
            "name": "test-base",
            "hidden": true,
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "debug",
            "inherits": "test-base",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "inherits": "test-base",
            "configurePreset": "release"
        },
        {
            "name": "asan",
            "inherits": "test-base",
            "configurePreset": "asan"
        },
        {
            "name": "coverage",
            "inherits": "test-base",
            "configurePreset": "coverage"
        }
    ]
}
